<style>
  .hv-wrap{padding:52px 0;overflow:visible;width:100vw;margin-left:calc(-50vw + 50%);max-width:none;position:relative}
  .hv-h{font-family:'DM Sans',sans-serif;font-weight:700;color:#1B2A4A;text-align:center;font-size:clamp(2rem,3.5vw,2.6rem);margin:0 0 .4rem}
  .hv-sub{text-align:center;color:#5b6172;font-size:1.15rem;margin:0 0 2rem}
  .hv-grid{display:flex;flex-direction:row;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding:32px 2rem 40px;cursor:grab;}
  .hv-grid::-webkit-scrollbar{display:none;}
  .hv-card{position:relative;flex:0 0 380px;scroll-snap-align:start;border-radius:14px;overflow:hidden;text-decoration:none;background:#1B2A4A;aspect-ratio:16/9;}
  @media(min-width:1024px){.hv-card{flex:0 0 480px;}}
  @media(max-width:767px){.hv-card{flex:0 0 80vw;}}
  .hv-vid{width:100%;height:100%;object-fit:cover;display:block;}
  .hv-ov{position:absolute;left:0;right:0;bottom:0;padding:12px 16px;background:linear-gradient(to top,rgba(27,42,74,.9),transparent);font-family:'DM Sans',sans-serif;}
  .hv-t{color:#fff;font-weight:700;font-size:.95rem;display:block;}
  .hv-p{color:#D4A853;font-weight:600;font-size:.9rem;display:block;margin-top:2px;}
  .hv-arr{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:50%;border:none;background:rgba(255,255,255,0.9);color:#1B2A4A;font-size:1.8rem;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,.15);}
  .hv-arr--l{left:8px;}.hv-arr--r{right:8px;}
  /* FIX 5 — coverflow: center card pops */
  .hv-card{transition:transform .35s ease, box-shadow .35s ease, opacity .35s ease;transform:scale(0.85);opacity:0.6;}
  .hv-card.hv-card--center{transform:scale(1.15);opacity:1;box-shadow:0 28px 60px rgba(27,42,74,.45);z-index:2;}
  /* Mobile coverflow: same effect, softer scale so the 80vw center card doesn't fill/overflow the screen and neighbours still peek */
  @media(max-width:767px){
    .hv-card{transform:scale(0.90);opacity:0.68;}
    .hv-card.hv-card--center{transform:scale(1.08);opacity:1;box-shadow:0 16px 36px rgba(27,42,74,.4);}
  }
</style>
<script>
  (function(){
    var vids=[].slice.call(document.querySelectorAll('.hv-vid'));
    if(!vids.length) return;
    function load(v){ var s=v.querySelector('source[data-src]'); if(s && !s.src){ s.src=s.getAttribute('data-src'); v.load(); } }
    function play(v){ var pr=v.play(); if(pr&&pr.catch)pr.catch(function(){}); }
    function activate(v){ load(v); play(v); }
    if(!('IntersectionObserver' in window)){ vids.forEach(activate); }
    else { var io=new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ activate(e.target); } else { e.target.pause(); } }); },{threshold:0.4}); vids.forEach(function(v){ io.observe(v); }); }
  })();
  (function(){
    var grid=document.querySelector('.hv-grid');
    if(grid){var isDown=false,startX,scrollLeft;
    grid.addEventListener('mousedown',function(e){isDown=true;grid.style.cursor='grabbing';startX=e.pageX-grid.offsetLeft;scrollLeft=grid.scrollLeft;});
    grid.addEventListener('mouseleave',function(){isDown=false;grid.style.cursor='grab';});
    grid.addEventListener('mouseup',function(){isDown=false;grid.style.cursor='grab';});
    grid.addEventListener('mousemove',function(e){if(!isDown)return;e.preventDefault();var x=e.pageX-grid.offsetLeft;grid.scrollLeft=scrollLeft-(x-startX)*1.5;});}
  })();
  (function(){
    var grid=document.querySelector('.hv-grid');var wrap=document.querySelector('.hv-wrap');
    if(!grid||!wrap) return;
    var btnL=document.createElement('button');btnL.className='hv-arr hv-arr--l';btnL.innerHTML='&#8249;';
    var btnR=document.createElement('button');btnR.className='hv-arr hv-arr--r';btnR.innerHTML='&#8250;';
    wrap.style.position='relative';
    wrap.appendChild(btnL);wrap.appendChild(btnR);
    btnL.addEventListener('click',function(){grid.scrollBy({left:-500,behavior:'smooth'});});
    btnR.addEventListener('click',function(){grid.scrollBy({left:500,behavior:'smooth'});});
  })();
  (function(){
    function updateCenterCard(){
      var grid=document.querySelector('.hv-grid');
      if(!grid) return;
      var cards=[].slice.call(grid.querySelectorAll('.hv-card'));
      var gridRect=grid.getBoundingClientRect();
      var gridCenter=gridRect.left+gridRect.width/2;
      var closest=null, closestDist=Infinity;
      cards.forEach(function(c){
        var r=c.getBoundingClientRect();
        var cardCenter=r.left+r.width/2;
        var dist=Math.abs(cardCenter-gridCenter);
        if(dist<closestDist){closestDist=dist;closest=c;}
      });
      cards.forEach(function(c){c.classList.toggle('hv-card--center', c===closest);});
    }
    var grid=document.querySelector('.hv-grid');
    if(grid){
      grid.addEventListener('scroll', function(){ requestAnimationFrame(updateCenterCard); });
      window.addEventListener('resize', updateCenterCard);
      updateCenterCard();
    }
  })();
</script>
