{%- comment -%}
  lc_ugc_video_reel — homepage "Voyez-le chez vous" UGC unboxing video reel.
  Coverflow of 5 vertical (9:16) customer unboxing videos, each with a docked
  product card (title FR/EN + live Shopify price + PDP link). Data is fetched
  client-side from the aosom-sync app (/api/ugc-videos), so the 5 products track
  live stock + Shopify titles/prices without touching the theme. Bilingual via
  request.locale, navy/gold, responsive. Fails closed: if the fetch returns
  nothing the section stays hidden (no empty heading on the homepage).
{%- endcomment -%}
{%- assign loc = request.locale.iso_code | downcase -%}
<div class="lcugc-wrap" data-lcugc hidden style="background:#FAFAF8">
  <div class="page-width lcugc-inner">
    <h2 class="lcugc-h">{% if loc == 'en' %}See it at home{% else %}Voyez-le chez vous{% endif %}</h2>
    <p class="lcugc-sub">{% if loc == 'en' %}Real unboxings, filmed by real customers{% else %}De vrais déballages, filmés par de vrais clients{% endif %}</p>
    <div class="lcugc-viewport">
      <button class="lcugc-arr lcugc-arr--l" type="button" aria-label="{% if loc == 'en' %}Previous{% else %}Précédent{% endif %}">&#8249;</button>
      <ul class="lcugc-track" role="list"></ul>
      <button class="lcugc-arr lcugc-arr--r" type="button" aria-label="{% if loc == 'en' %}Next{% else %}Suivant{% endif %}">&#8250;</button>
    </div>
    <ul class="lcugc-dots" role="list" aria-hidden="true"></ul>
  </div>
</div>
<style>
  .lcugc-wrap{padding:52px 0;overflow:visible;width:100vw;margin-left:calc(-50vw + 50%);max-width:none;position:relative;isolation:isolate}
  .lcugc-wrap[hidden]{display:none}
  .lcugc-h{font-family:'DM Sans',sans-serif;font-weight:700;color:#1B2A4A;text-align:center;font-size:clamp(2rem,3.5vw,2.6rem);margin:0 0 .4rem}
  .lcugc-sub{text-align:center;color:#5b6172;font-size:1.15rem;margin:0 0 1.6rem}
  .lcugc-viewport{position:relative}
  .lcugc-track{display:flex;flex-direction:row;gap:18px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;list-style:none;margin:0;padding:28px 50% 28px;cursor:grab}
  .lcugc-track::-webkit-scrollbar{display:none}
  .lcugc-card{position:relative;flex:0 0 300px;scroll-snap-align:center;border-radius:18px;overflow:hidden;background:#1B2A4A;aspect-ratio:9/16;transition:transform .35s ease,box-shadow .35s ease,opacity .35s ease;transform:scale(.82);opacity:.58}
  .lcugc-card.is-center{transform:scale(1);opacity:1;box-shadow:0 28px 60px rgba(27,42,74,.45);z-index:2}
  @media(min-width:1024px){.lcugc-card{flex:0 0 340px}}
  @media(max-width:767px){.lcugc-track{padding:18px 50% 22px;gap:12px}.lcugc-card{flex:0 0 66vw;transform:scale(.88);opacity:.66}.lcugc-card.is-center{transform:scale(1.02);box-shadow:0 16px 36px rgba(27,42,74,.4)}}
  .lcugc-vid{width:100%;height:100%;object-fit:cover;display:block;background:#1B2A4A}
  .lcugc-shade{position:absolute;inset:0;z-index:1;text-decoration:none}
  .lcugc-meta{position:absolute;left:0;right:0;bottom:0;z-index:2;pointer-events:none;padding:34px 16px 14px;background:linear-gradient(to top,rgba(27,42,74,.92),rgba(27,42,74,.35),transparent);font-family:'DM Sans',sans-serif}
  .lcugc-t{color:#fff;font-weight:700;font-size:.95rem;line-height:1.25;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .lcugc-p{color:#D4A853;font-weight:700;font-size:1rem;display:block;margin-top:4px}
  .lcugc-ctrl{position:absolute;z-index:3;width:38px;height:38px;border-radius:50%;border:none;background:rgba(27,42,74,.55);color:#fff;cursor:pointer;display:none;align-items:center;justify-content:center;backdrop-filter:blur(2px);transition:background .2s ease}
  .lcugc-ctrl:hover{background:rgba(212,168,83,.92);color:#1B2A4A}
  .lcugc-ctrl svg{width:18px;height:18px;fill:currentColor;display:block}
  .lcugc-card.is-center .lcugc-ctrl{display:flex}
  .lcugc-play{top:12px;left:12px}
  .lcugc-mute{bottom:64px;right:12px}
  .lcugc-arr{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:46px;height:46px;border-radius:50%;border:none;background:rgba(255,255,255,.94);color:#1B2A4A;font-size:1.9rem;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(27,42,74,.18)}
  .lcugc-arr:hover{background:#D4A853;color:#fff}
  .lcugc-arr--l{left:12px}.lcugc-arr--r{right:12px}
  @media(max-width:767px){.lcugc-arr{display:none}}
  .lcugc-dots{display:flex;justify-content:center;gap:8px;margin:16px 0 0;padding:0;list-style:none}
  .lcugc-dot{width:8px;height:8px;border-radius:999px;background:rgba(27,42,74,.22);border:none;padding:0;cursor:pointer;transition:background .3s ease,width .3s ease}
  .lcugc-dot.is-active{width:22px;background:#D4A853}
</style>
<script>
(function(){
  var wrap=document.querySelector('[data-lcugc]');
  if(!wrap||wrap.dataset.lcugcInit) return;
  wrap.dataset.lcugcInit='1';
  var LOC={% if loc == 'en' %}'en'{% else %}'fr'{% endif %};
  var ROOT={{ routes.root_url | json }};
  var API='https://aosom-sync.vercel.app/api/ugc-videos';
  var LBL={play:LOC==='en'?'Play':'Lecture',pause:LOC==='en'?'Pause':'Pause',mute:LOC==='en'?'Unmute':'Activer le son',muted:LOC==='en'?'Mute':'Couper le son'};
  var ICON={
    play:'<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>',
    pause:'<svg viewBox="0 0 24 24"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>',
    sound:'<svg viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm13.5 2a4.5 4.5 0 0 0-2.5-4v8a4.5 4.5 0 0 0 2.5-4z"/></svg>',
    muted:'<svg viewBox="0 0 24 24"><path d="M3 10v4h4l5 5V5L7 10H3zm16.6 2 2.1-2.1-1.4-1.4L18.2 10.6 16 8.4l-1.4 1.4 2.1 2.2-2.1 2.1 1.4 1.4 2.2-2.1 2.1 2.1 1.4-1.4z"/></svg>'
  };
  var track=wrap.querySelector('.lcugc-track');
  var dotsWrap=wrap.querySelector('.lcugc-dots');
  var arrL=wrap.querySelector('.lcugc-arr--l'), arrR=wrap.querySelector('.lcugc-arr--r');
  var esc=function(s){var d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;};
  var money=function(n){return (typeof n==='number'&&isFinite(n))?'$'+n.toFixed(2):'';};

  fetch(API,{headers:{'Accept':'application/json'}}).then(function(r){return r.ok?r.json():null;}).then(function(data){
    var items=(data&&data.items)||[];
    if(!items.length){return;}
    var cards=[], dots=[];
    items.forEach(function(it,i){
      var title=(LOC==='en'? (it.titleEn||it.titleFr):(it.titleFr||it.titleEn))||'';
      var href=String(ROOT).replace(/\/+$/,'')+'/products/'+it.handle;
      var li=document.createElement('li');
      li.className='lcugc-card';
      li.innerHTML=
        '<video class="lcugc-vid" muted loop playsinline preload="none"'+(it.imageUrl?(' poster="'+esc(it.imageUrl)+'"'):'')+'>'+
          '<source data-src="'+esc(it.videoUrl)+'" type="video/mp4"></video>'+
        '<button class="lcugc-ctrl lcugc-play" type="button" aria-label="'+esc(LBL.pause)+'">'+ICON.pause+'</button>'+
        '<button class="lcugc-ctrl lcugc-mute" type="button" aria-label="'+esc(LBL.mute)+'">'+ICON.muted+'</button>'+
        '<a class="lcugc-shade" href="'+esc(href)+'" aria-label="'+esc(title)+'" data-umami-event="UGC reel '+esc(it.sku)+'"></a>'+
        '<div class="lcugc-meta"><span class="lcugc-t">'+esc(title)+'</span>'+(money(it.price)?('<span class="lcugc-p">'+money(it.price)+'</span>'):'')+'</div>';
      track.appendChild(li);
      cards.push(li);
      // Clicking anywhere on the card (incl. the video itself) opens the PDP.
      // The play/pause + mute controls call stopPropagation, so they don't navigate.
      li.style.cursor='pointer';
      li.addEventListener('click',function(){ window.location.href=href; });
      var dot=document.createElement('button');
      dot.className='lcugc-dot';dot.type='button';dot.setAttribute('aria-label',(i+1)+' / '+items.length);
      dot.addEventListener('click',function(){li.scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});});
      dotsWrap.appendChild(dot);dots.push(dot);

      // per-card video controls (play/pause + mute), kept off the PDP link
      var vid=li.querySelector('.lcugc-vid');
      var playBtn=li.querySelector('.lcugc-play'), muteBtn=li.querySelector('.lcugc-mute');
      playBtn.addEventListener('click',function(e){e.preventDefault();e.stopPropagation();
        if(vid.paused){var p=vid.play();if(p&&p.catch)p.catch(function(){});playBtn.innerHTML=ICON.pause;playBtn.setAttribute('aria-label',LBL.pause);}
        else{vid.pause();playBtn.innerHTML=ICON.play;playBtn.setAttribute('aria-label',LBL.play);}});
      muteBtn.addEventListener('click',function(e){e.preventDefault();e.stopPropagation();
        vid.muted=!vid.muted;
        muteBtn.innerHTML=vid.muted?ICON.muted:ICON.sound;
        muteBtn.setAttribute('aria-label',vid.muted?LBL.mute:LBL.muted);});
    });

    function loadVid(v){var s=v.querySelector('source[data-src]');if(s&&!s.src){s.src=s.getAttribute('data-src');v.load();}}

    // autoplay the centered video, pause the rest
    if('IntersectionObserver' in window){
      var io=new IntersectionObserver(function(es){es.forEach(function(e){var v=e.target;
        if(e.isIntersecting){loadVid(v);var p=v.play();if(p&&p.catch)p.catch(function(){});}
        else{v.pause();}});},{root:track,threshold:0.6});
      cards.forEach(function(c){io.observe(c.querySelector('.lcugc-vid'));});
    } else { cards.forEach(function(c){var v=c.querySelector('.lcugc-vid');loadVid(v);v.play();}); }

    function updateCenter(){
      var gr=track.getBoundingClientRect(), mid=gr.left+gr.width/2, best=null,bi=0,bd=Infinity;
      cards.forEach(function(c,i){var r=c.getBoundingClientRect(),cc=r.left+r.width/2,d=Math.abs(cc-mid);if(d<bd){bd=d;best=c;bi=i;}});
      cards.forEach(function(c){c.classList.toggle('is-center',c===best);});
      dots.forEach(function(d,i){d.classList.toggle('is-active',i===bi);});
    }
    track.addEventListener('scroll',function(){requestAnimationFrame(updateCenter);});
    window.addEventListener('resize',updateCenter);

    // arrows
    function step(dir){var w=cards[0]?cards[0].getBoundingClientRect().width+18:360;track.scrollBy({left:dir*w,behavior:'smooth'});}
    if(arrL)arrL.addEventListener('click',function(){step(-1);});
    if(arrR)arrR.addEventListener('click',function(){step(1);});

    // drag-to-scroll (desktop)
    var down=false,sx,sl;
    track.addEventListener('mousedown',function(e){down=true;track.style.cursor='grabbing';sx=e.pageX-track.offsetLeft;sl=track.scrollLeft;});
    track.addEventListener('mouseleave',function(){down=false;track.style.cursor='grab';});
    track.addEventListener('mouseup',function(){down=false;track.style.cursor='grab';});
    track.addEventListener('mousemove',function(e){if(!down)return;e.preventDefault();var x=e.pageX-track.offsetLeft;track.scrollLeft=sl-(x-sx)*1.4;});

    wrap.hidden=false;
    // center on the middle card and paint the initial center state
    requestAnimationFrame(function(){
      var mididx=Math.floor(cards.length/2);
      if(cards[mididx])cards[mididx].scrollIntoView({inline:'center',block:'nearest'});
      updateCenter();
    });
  }).catch(function(){/* fail closed: leave the section hidden */});
})();
</script>
