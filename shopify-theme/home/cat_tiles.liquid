{%- assign loc = request.locale.iso_code | downcase -%}
{%- if loc == 'en' -%}{%- assign kick = 'Category' -%}{%- assign cta = 'Shop' -%}{%- else -%}{%- assign kick = 'Cat&eacute;gorie' -%}{%- assign cta = 'Magasiner' -%}{%- endif -%}
<style>
/* Mobile (<=767px): horizontal snap-scroll carousel. Desktop keeps the grid from lc-home.css. */
@media (max-width: 767px){
  .lc-cat .lc-cat-grid{
    display:flex;
    flex-wrap:nowrap;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    grid-auto-rows:initial;
  }
  .lc-cat .lc-cat-grid::-webkit-scrollbar{display:none;}
  .lc-cat .lc-cat-tile,
  .lc-cat .lc-cat-tile--lg{
    flex:0 0 62vw;
    height:200px;
    scroll-snap-align:start;
    border-radius:12px;
  }
}
/* Rabais tile: gold overlay (#D4A853) instead of the navy veil */
.lc-cat-tile--rabais .lc-cat-tile__ov{
  background:linear-gradient(to top, rgba(212,168,83,.85) 0%, rgba(212,168,83,.35) 45%, rgba(212,168,83,.06) 72%, rgba(212,168,83,0) 100%);
}
.lc-cat-tile--rabais:hover .lc-cat-tile__ov{
  background:linear-gradient(to top, rgba(212,168,83,.78) 0%, rgba(212,168,83,.28) 50%, rgba(212,168,83,0) 100%);
}
</style>
<div class="page-width lc-cat lc-reveal">
  <h2 class="lc-cat__title">{% if loc == 'en' %}Shop by category{% else %}Magasinez par cat&eacute;gorie{% endif %}</h2>
  <div class="lc-cat-grid">
    <a class="lc-cat-tile lc-cat-tile--lg" href="/collections/meubles-et-decorations" data-umami-event="Cat tile Furniture & decor">
      <span class="lc-cat-tile__img" style="background-image:url('{{ 'cat-tile-1.jpg' | asset_url }}')"></span>
      <span class="lc-cat-tile__ov"></span>
      <span class="lc-cat-tile__body">
        <span class="lc-cat-tile__kicker">{{ kick }}</span>
        <span class="lc-cat-tile__label">{% if loc == 'en' %}Furniture &amp; decor{% else %}Meubles et d&eacute;corations{% endif %}</span>
        <span class="lc-cat-tile__cta">{{ cta }} <span aria-hidden="true">&rarr;</span></span>
      </span>
    </a>
    <a class="lc-cat-tile" href="/collections/mobiliers-exterieurs-et-jardins" data-umami-event="Cat tile Outdoor & garden">
