# Shopify Admin API
SHOPIFY_ACCESS_TOKEN=

# Claude API for content generation
ANTHROPIC_API_KEY=

# Cron secret (for scheduled sync endpoint)
CRON_SECRET=

# Session-token signing key — MUST be high-entropy and DISTINCT from AUTH_PASSWORD.
# Signs the dashboard session cookie (HMAC-SHA256). Keeping it separate from the human
# login password prevents any issued token from being an offline cracking oracle for
# the admin secret. If unset, session signing falls back to AUTH_PASSWORD (the old, weak
# behavior) — set this to activate the fix. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Simple auth password for the 2 users (seeds the "admin" user on first login).
# Also serves as the DB-independent emergency admin login: if Turso is down/over
# quota, logging in as "admin" with this password still works (no DB lookup).
AUTH_PASSWORD=

# Meta App Review reviewer account. Seeds a "meta-review" user with the
# "reviewer" role, which can only access /social and /settings. Revoke after
# Meta approves the app by removing this env var and deleting the user row.
META_REVIEW_PASSWORD=

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=  # Meta Business Suite → Events Manager. When unset, the injected ScriptTag is a no-op.

# Vercel Blob — durable storage for generated videos (and sync-run blobs).
# Vercel dashboard → Storage → Blob store → Read/Write Token. When unset, the
# video pipeline skips the upload and serves renders from the local filesystem.
BLOB_READ_WRITE_TOKEN=
